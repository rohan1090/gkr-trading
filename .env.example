# GKR Trading — Environment Variables
# Copy to .env and fill in your values.

# ── Alpaca Paper Trading (required for trading + market data) ─────────
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
# Optional: override paper API base URL (default: https://paper-api.alpaca.markets)
# ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# ── Alpaca Data API tickers (optional, for observation plane + TUI) ───
ALPACA_EQUITY_TICKERS=SPY,QQQ,AAPL,TSLA,NVDA,MSFT,AMZN,META,GOOGL,AMD
ALPACA_OPTIONS_TICKERS=
# Legacy TUI watchlist (used by MarketPoller if set)
# ALPACA_WATCHLIST=AAPL,SPY,QQQ,TSLA,NVDA,MSFT

# ── Charles Schwab API (optional — real account positions) ────────────
# SCHWAB_CLIENT_ID=              # App Key from developer.schwab.com
# SCHWAB_CLIENT_SECRET=          # App Secret from developer.schwab.com
# SCHWAB_ACCESS_TOKEN=           # OAuth2 access token
# SCHWAB_REFRESH_TOKEN=          # OAuth2 refresh token
# SCHWAB_ACCOUNT_HASH=           # Account hash from GET /trader/v1/accounts

# ── Supabase (optional — enables multi-device sync) ──────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here
# Or use service key for server-side write access:
# SUPABASE_SERVICE_KEY=your_service_key_here
